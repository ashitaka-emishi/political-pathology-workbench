{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://political-pathology-workbench.local/schemas/case.schema.json",
  "title": "Case",
  "type": "object",
  "required": ["caseId", "title", "subtype", "outcome", "publicationStatus", "reviewStatus", "sacredPoliticalOrderId", "sacredPoliticalOrderName", "sacredPoliticalOrderDefinition", "sacredPoliticalOrderStrength", "sacredPoliticalOrderStrengthRationale", "caseSelectionRole", "selectionRationale", "theoryTest"],
  "properties": {
    "caseId": { "type": "string" },
    "title": { "type": "string" },
    "subtype": {
      "type": "string",
      "enum": ["regime", "war", "revolution", "movement", "collapse", "transition", "civil-religion", "empire", "postwar-order", "anti-sacrificial-movement", "hybrid"]
    },
    "period": { "type": "string" },
    "outcome": { "$ref": "controlled-vocab.schema.json#/$defs/outcome" },
    "sacredPoliticalOrderId": { "type": "string" },
    "sacredPoliticalOrderName": { "type": "string" },
    "sacredPoliticalOrderDefinition": { "type": "string" },
    "sacredPoliticalOrderStrength": {
      "type": "number",
      "minimum": 0,
      "maximum": 5
    },
    "sacredPoliticalOrderStrengthRationale": { "type": "string" },
    "caseSelectionRole": { "$ref": "controlled-vocab.schema.json#/$defs/caseSelectionRole" },
    "selectionRationale": { "type": "string" },
    "theoryTest": { "type": "string" },
    "goldCase": { "type": "boolean" },
    "publicationStatus": { "$ref": "controlled-vocab.schema.json#/$defs/publicationStatus" },
    "reviewStatus": { "$ref": "controlled-vocab.schema.json#/$defs/reviewStatus" },
    "audience": { "type": "string" },
    "theoryVersions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "summary": { "type": "string" }
  }
}
