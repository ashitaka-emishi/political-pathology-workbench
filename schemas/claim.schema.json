{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://political-pathology-workbench.local/schemas/claim.schema.json",
  "title": "Claims",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["claimId", "caseId", "claim", "derivedFrom", "createdBy", "reviewStatus"],
    "properties": {
      "claimId": { "type": "string" },
      "caseId": { "type": "string" },
      "claim": { "type": "string" },
      "derivedFrom": {
        "type": "array",
        "items": { "type": "string" }
      },
      "createdBy": {
        "type": "string",
        "enum": ["human", "ai", "script", "imported"]
      },
      "reviewedBy": { "type": "string" },
      "reviewStatus": { "$ref": "controlled-vocab.schema.json#/$defs/reviewStatus" },
      "publicationStatus": { "$ref": "controlled-vocab.schema.json#/$defs/publicationStatus" },
      "confidence": { "type": "object" }
    }
  }
}
