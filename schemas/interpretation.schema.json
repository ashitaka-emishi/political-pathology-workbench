{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://political-pathology-workbench.local/schemas/interpretation.schema.json",
  "title": "Interpretations",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["interpretationId", "caseId", "claimIds", "theoryId", "variableId", "interpretation", "reviewStatus"],
    "properties": {
      "interpretationId": { "type": "string" },
      "caseId": { "type": "string" },
      "claimIds": {
        "type": "array",
        "items": { "type": "string" }
      },
      "theoryId": { "type": "string" },
      "variableId": { "type": "string" },
      "mechanism": { "$ref": "controlled-vocab.schema.json#/$defs/mechanism" },
      "mechanismSummary": { "type": "string" },
      "alternativeMechanisms": {
        "type": "array",
        "items": { "$ref": "controlled-vocab.schema.json#/$defs/mechanism" }
      },
      "sacrificeForm": {
        "type": "array",
        "items": { "$ref": "controlled-vocab.schema.json#/$defs/sacrificeForm" }
      },
      "sacrificeHealth": { "$ref": "controlled-vocab.schema.json#/$defs/sacrificeHealth" },
      "sacrificeBoundedness": { "$ref": "controlled-vocab.schema.json#/$defs/sacrificeBoundedness" },
      "sacrificeTarget": { "$ref": "controlled-vocab.schema.json#/$defs/sacrificeTarget" },
      "definitionRefs": {
        "type": "array",
        "items": { "type": "string" }
      },
      "codebookVersion": { "type": "string" },
      "interpretation": { "type": "string" },
      "reviewStatus": { "$ref": "controlled-vocab.schema.json#/$defs/reviewStatus" },
      "publicationStatus": { "$ref": "controlled-vocab.schema.json#/$defs/publicationStatus" },
      "confidence": { "type": "object" }
    }
  }
}
