{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://political-pathology-workbench.local/schemas/counterclaim.schema.json",
  "title": "Counterclaims",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "counterclaimId",
      "caseId",
      "claim",
      "effect",
      "targetClaimIds",
      "sourceIds",
      "rationale",
      "reviewStatus",
      "publicationStatus"
    ],
    "properties": {
      "counterclaimId": { "type": "string" },
      "caseId": { "type": "string" },
      "claim": { "type": "string" },
      "effect": { "$ref": "controlled-vocab.schema.json#/$defs/counterclaimEffect" },
      "targetClaimIds": {
        "type": "array",
        "items": { "type": "string" }
      },
      "sourceIds": {
        "type": "array",
        "items": { "type": "string" }
      },
      "rationale": { "type": "string" },
      "reviewStatus": { "$ref": "controlled-vocab.schema.json#/$defs/reviewStatus" },
      "publicationStatus": { "$ref": "controlled-vocab.schema.json#/$defs/publicationStatus" }
    }
  }
}
